# Append these lines to the repo's existing .gitignore.
# Repo IS the active theme. WordPress lives under .ddev/wp/ (gitignored)
# with the active theme directory inside it symlinked back to the repo root.

# Local-only
.env
.DS_Store
node_modules

# DDEV runtime (WordPress install lives here, gitignored)
.ddev/wp/
.ddev/wp-config-local.php
.ddev/.wordpress/
.ddev/db_snapshots/
.ddev/import-db/

# Addon-installed files (regenerated by `ddev rpx-init`)
.ddev/addon-metadata/
.ddev/templates/
.ddev/php/
.ddev/nginx_full/
.ddev/commands/host/rpx-setup
.ddev/commands/host/rpx-pull
.ddev/commands/host/rpx-db
.ddev/commands/host/rpx-files
