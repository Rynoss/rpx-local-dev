#!/bin/bash
#ddev-generated

## Description: First-time project setup (WP core, files + DB from WP Engine)
## Usage: rpx-setup
## Example: ddev rpx-setup

set -e

if [ ! -f .env ]; then
  echo "Error: .env file not found. Create it first."
  exit 1
fi
source .env

if [ -z "$WPENGINE_ENV" ] || [ -z "$ACTIVE_THEME_NAME" ]; then
  echo "Error: WPENGINE_ENV and ACTIVE_THEME_NAME must be set in .env"
  exit 1
fi

echo ""
echo "============================================"
echo "RPX Local Dev Setup"
echo "Environment: $WPENGINE_ENV"
echo "Active theme: $ACTIVE_THEME_NAME"
if [ "$IS_MULTISITE" = "yes" ]; then
  echo "Type: Multisite Network"
fi
echo "============================================"
echo ""

# 1. Ensure docroot directory exists (blueprint config.yaml sets docroot: .ddev/wp)
mkdir -p .ddev/wp

# 2. Seed wp-config-local.php from template if it doesn't exist (preserve user edits)
if [ ! -f .ddev/wp-config-local.php ]; then
  cp .ddev/templates/wp-config-local.php .ddev/wp-config-local.php
fi

# 3. Multisite Nginx config (only if needed)
if [ "$IS_MULTISITE" = "yes" ]; then
  echo "Installing multisite Nginx config..."
  mkdir -p .ddev/nginx_full
  cat > .ddev/nginx_full/nginx-site.conf << 'NGINXEOF'
server {
    listen 80 default_server;
    listen 443 ssl default_server;
    root /var/www/html/.ddev/wp;
    ssl_certificate /etc/ssl/certs/master.crt;
    ssl_certificate_key /etc/ssl/certs/master.key;
    include /etc/nginx/monitoring.conf;
    index index.php index.htm index.html;
    sendfile off;
    error_log /dev/stdout info;
    access_log /var/log/nginx/access.log;

    location = /favicon.ico { log_not_found off; access_log off; }
    location = /robots.txt { allow all; log_not_found off; access_log off; }
    location ~ /\. { deny all; }
    location ~* /(?:uploads|files)/.*\.php$ { deny all; }

    if (!-e $request_filename) {
        rewrite /wp-admin$ $scheme://$host$uri/ permanent;
        rewrite ^/[_0-9a-zA-Z-]+(/wp-.*) $1 last;
        rewrite ^/[_0-9a-zA-Z-]+(/.*\.php)$ $1 last;
    }

    location / {
        absolute_redirect off;
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php-fpm.sock;
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param SCRIPT_NAME $fastcgi_script_name;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_intercept_errors off;
        fastcgi_read_timeout 10m;
        fastcgi_param SERVER_NAME $host;
        fastcgi_param HTTPS $fcgi_https;
    }

    location ~* \.(jpg|jpeg|gif|png|ico|cur|gz|svg|svgz|mp4|ogg|ogv|webm|webp|htc)$ {
        expires max;
        log_not_found off;
        try_files $uri /index.php$is_args$args;
    }

    location ~* \.(js|css)$ {
        expires -1;
        log_not_found off;
    }

    include /etc/nginx/common.d/*.conf;
}
NGINXEOF
fi

# 4. Restart DDEV to apply nginx config + auto_prepend_file PHP setting
echo "Restarting DDEV..."
ddev restart

# 5. Load SSH keys
echo "Loading SSH keys..."
ddev auth ssh

# 6. Install WordPress core into .ddev/wp/ if missing
if ! ddev exec test -f .ddev/wp/wp-includes/version.php 2>/dev/null; then
  echo "Downloading WordPress core into .ddev/wp/..."
  ddev exec wp core download --path=/var/www/html/.ddev/wp --allow-root
fi

# 7. Symlink active theme back to repo root (so the repo IS the theme)
mkdir -p .ddev/wp/wp-content/themes
THEME_PATH=".ddev/wp/wp-content/themes/${ACTIVE_THEME_NAME}"
if [ ! -L "$THEME_PATH" ]; then
  rm -rf "$THEME_PATH"
  # 5 levels up from .ddev/wp/wp-content/themes/<active>/ = repo root
  ln -s ../../../../.. "$THEME_PATH"
  echo "Symlinked ${THEME_PATH} -> repo root"
fi

# 8. Install Codespaces mu-plugin (harmless locally)
mkdir -p .ddev/wp/wp-content/mu-plugins
cp -f .ddev/templates/codespaces-fix.php .ddev/wp/wp-content/mu-plugins/codespaces-fix.php

# 9. Pull files and database from WP Engine
ddev rpx-files
ddev rpx-db

# 10. Set multisite constants in wp-config-local.php (loaded by PHP auto_prepend_file)
if [ "$IS_MULTISITE" = "yes" ]; then
  SITE_URL=$(ddev describe -j | grep -o '"https://[^"]*"' | head -1 | tr -d '"')
  LOCAL_DOMAIN=$(echo "$SITE_URL" | sed -E 's|https?://||')

  if ! grep -q "MULTISITE" .ddev/wp-config-local.php; then
    cat >> .ddev/wp-config-local.php <<MSEOF

// Multisite (auto-added by rpx-setup)
define('WP_ALLOW_MULTISITE', true);
define('MULTISITE', true);
define('SUBDOMAIN_INSTALL', false);
define('DOMAIN_CURRENT_SITE', '${LOCAL_DOMAIN}');
define('PATH_CURRENT_SITE', '/');
define('SITE_ID_CURRENT_SITE', 1);
define('BLOG_ID_CURRENT_SITE', 1);
MSEOF
  fi
fi

echo ""
echo "============================================"
SITE_URL=$(ddev describe -j | grep -o '"https://[^"]*"' | head -1 | tr -d '"')
echo "Setup complete!"
echo "Site: ${SITE_URL}"
echo "Admin: ${SITE_URL}/wp-admin"
if [ "$IS_MULTISITE" = "yes" ]; then
  echo "Network Admin: ${SITE_URL}/wp-admin/network/"
fi
echo "Edit local PHP constants in: .ddev/wp-config-local.php"
echo "============================================"
